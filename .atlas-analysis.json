  "keyFeatures": [
    "Unified interface for multiple coding agents (Claude, OpenCode, Codex, Cursor)",
    "Normalized NDJSON event stream with 8 event types",
    "Model registry with human-friendly aliases",
    "Project-level configuration with harness.toml",
    "Multiple output formats (text, JSON, markdown, stream-json)",
    "Built-in timeout, budget limits, and graceful cancellation",
    "Session logging and diagnostics",
    "Rust library API for programmatic integration"
  ],
